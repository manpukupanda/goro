# Copy this file to .env and fill in the values before running docker-compose.
#
# S3 credentials for the storage backend.
# These values are also used as MinIO's MINIO_ROOT_USER / MINIO_ROOT_PASSWORD.
# MinIO requires GORO_S3_SECRET_KEY (= MINIO_ROOT_PASSWORD) to be at least 8 characters.
GORO_S3_ACCESS_KEY=change-me
GORO_S3_SECRET_KEY=change-me-8chars

# GORO_SECURE_LINK_SECRET is used by nginx's secure_link module and must be the same
# value on both the goro and nginx containers.
# For local development, any non-empty string works.
GORO_SECURE_LINK_SECRET=dev-secret-change-me

# Static API key required to access the public API endpoints (e.g. POST /videos,
# management endpoints). Use a strong random value in production.
GORO_API_KEY=change-me

# Admin console credentials. GORO_ADMIN_USER defaults to "admin" if not set.
# GORO_ADMIN_PASSWORD is required when --console is enabled.
GORO_ADMIN_USER=admin
GORO_ADMIN_PASSWORD=change-me
